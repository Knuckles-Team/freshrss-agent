@prefix fibo-fi: <https://spec.edmcouncil.org/fibo/ontology/FBC/FinancialInstruments/FinancialInstruments/> .
@prefix fibo-org: <https://spec.edmcouncil.org/fibo/ontology/FND/Organizations/Organizations/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <http://schema.org/> .

:RssFeed a owl:Class ;
    rdfs:label "RSS Feed" ;
    rdfs:comment "CONCEPT:KG-2.121 — a FeedSource backed by a native RSS/Atom feed URL, ingested by the zero-infra rss connector (no external service required)." ;
    rdfs:subClassOf :FeedSource .

:ingestedFrom a owl:ObjectProperty ;
    rdfs:label "ingested from" ;
    rdfs:comment "CONCEPT:KG-2.122 — provenance: the FeedSource an item was ingested from (the INGESTED_FROM edge written on the live sweep path)." ;
    rdfs:domain :FeedItem ;
    rdfs:range :FeedSource ;
    rdfs:seeAlso prov:wasDerivedFrom .

:publishesItem a owl:ObjectProperty ;
    rdfs:label "publishes item" ;
    rdfs:comment "CONCEPT:KG-2.122 — a FeedSource PUBLISHES the items ingested from it." ;
    rdfs:domain :FeedSource ;
    rdfs:range :FeedItem ;
    owl:inverseOf :itemFrom .

<http://knuckles.team/kg/feed> a owl:Ontology ;
    rdfs:label "Agent Intelligence Graph — Feed Ingestion Module" ;
    rdfs:comment "Unified RSS/Atom feed sources + items. Imported by the canonical <http://knuckles.team/kg> ontology; resolved to ontology_feed.ttl by the local loader convention." .

:itemFrom a owl:ObjectProperty ;
    rdfs:label "item from" ;
    rdfs:domain :FeedItem ;
    rdfs:range :FeedSource .

:FeedItem a owl:Class ;
    rdfs:label "Feed Item" ;
    rdfs:comment "CONCEPT:KG-2.122 — one entry ingested from a FeedSource (a Document specialization), carrying provenance back to the source it came from." ;
    rdfs:seeAlso schema:Article ;
    rdfs:subClassOf :Document .

:FeedSource a owl:Class ;
    rdfs:label "Feed Source" ;
    rdfs:comment """CONCEPT:KG-2.122 — a registered, first-class feed (a native
    RSS/Atom URL, the FreshRSS aggregator, or a ScholarX arXiv category) the unified
    feed pipeline ingests through the one world-model gate. The long-missing
    presets→KG materialization: a feed is a KG node, not just config.""" ;
    rdfs:subClassOf :DataConnector .

