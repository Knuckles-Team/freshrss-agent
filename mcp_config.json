{
  "mcpServers": {
    "freshrss-agent": {
      "command": "uv",
      "args": [
        "run",
        "freshrss-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "FRESHRSS_API_PASSWORD": "your_api_password_here",
        "FRESHRSS_URL": "http://localhost:8080",
        "FRESHRSS_USER": "admin",
        "READERTOOL": "True",
        "SUBSCRIPTIONSTOOL": "True"
      }
    }
  }
}
