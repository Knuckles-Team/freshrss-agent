{
  "mcpServers": {
    "freshrss-agent": {
      "command": "uv",
      "args": [
        "run",
        "freshrss-mcp"
      ],
      "env": {
        "FRESHRSS_URL": "<YOUR_FRESHRSS_URL>",
        "FRESHRSS_API_PASSWORD": "<YOUR_FRESHRSS_API_PASSWORD>",
        "FRESHRSS_AGENT_SSL_VERIFY": "<YOUR_FRESHRSS_AGENT_SSL_VERIFY>",
        "SYSTEMTOOL": "True"
      }
    }
  }
}
