{
  "mcpServers": {
    "freshrss-agent": {
      "command": "uv",
      "args": [
        "run",
        "freshrss-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "FRESHRSS_URL": "<YOUR_FRESHRSS_URL>",
        "FRESHRSS_USER": "<YOUR_FRESHRSS_USER>",
        "FRESHRSS_API_PASSWORD": "<YOUR_FRESHRSS_API_PASSWORD>",
        "FRESHRSS_SSL_VERIFY": "<YOUR_FRESHRSS_SSL_VERIFY>",
        "READERTOOL": "True",
        "SUBSCRIPTIONSTOOL": "True"
      }
    }
  }
}
